# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# Pokemon TCG API key (free: https://pokemontcg.io/dev). Optional but raises rate limits.
POKEMONTCG_API_KEY=

# PriceCharting API token (paid). Optional — only needed for Phase 7 enrichment.
PRICECHARTING_TOKEN=

# eBay Browse API (free dev keys: https://developer.ebay.com → create a keyset).
# Used for active-listing comps and to auto-read price from a pasted eBay link.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# Gmail SMTP for the daily digest.
# Enable 2-Step Verification on the account, then create an App Password for "Mail".
# Do NOT use your normal account password.
GMAIL_ADDRESS=thecardsquadco@gmail.com
GMAIL_APP_PASSWORD=
# Where the digest is sent (defaults to GMAIL_ADDRESS if blank).
DIGEST_TO=thecardsquadco@gmail.com
